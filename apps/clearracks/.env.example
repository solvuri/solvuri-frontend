# Base URL for @repo/api-client's createApiClient (used by lib/api.ts's clearracksApi)
NEXT_PUBLIC_API_URL=https://api.solvuri.com/v1

# Production root domain for subdomain-based storefront routing (proxy.ts).
# Falls back to "clearrack.xyz" if unset — only needs setting to override that.
ROOT_DOMAIN=clearrack.xyz
